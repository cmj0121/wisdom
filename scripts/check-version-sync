#!/usr/bin/env bash
# Version integrity checks for the marketplace:
#   1. Every marketplace.json plugin version matches its plugin.json version.
#   2. The marketplace.json top-level version never lags the latest git tag
#      (equal = released, ahead = next release in prep, behind = error).
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LATEST_TAG="$(git -C "$REPO_ROOT" tag --sort=-v:refname --list 'v*' 2>/dev/null | head -n1 || true)"

python3 - "$REPO_ROOT" "$LATEST_TAG" <<'PY'
import json, os, sys

root = sys.argv[1]
latest_tag = sys.argv[2] if len(sys.argv) > 2 else ""
mk = json.load(open(os.path.join(root, ".claude-plugin", "marketplace.json")))

GREEN, RED, RESET = "\033[32m", "\033[31m", "\033[0m"
errors = 0


def ok(msg):
    print(f"  {GREEN}PASS{RESET} {msg}")


def bad(msg):
    global errors
    print(f"  {RED}FAIL{RESET} {msg}")
    errors += 1


print("==> Checking marketplace.json <-> plugin.json version sync")
for p in mk["plugins"]:
    name = p["name"]
    mk_ver = p.get("version", "")
    src = p["source"][2:] if p["source"].startswith("./") else p["source"]
    pj_path = os.path.join(root, src, ".claude-plugin", "plugin.json")
    if not os.path.isfile(pj_path):
        bad(f"{name}: missing {os.path.relpath(pj_path, root)}")
        continue
    pj_ver = json.load(open(pj_path)).get("version", "")
    if mk_ver == pj_ver:
        ok(f"{name} {mk_ver}")
    else:
        bad(f"{name}: marketplace={mk_ver} != plugin.json={pj_ver}")


def semver(v):
    """Leading numeric components of a version/tag, e.g. 'v1.3.1' -> (1, 3, 1)."""
    out = []
    for part in v.lstrip("v").split("."):
        digits = ""
        for ch in part:
            if ch.isdigit():
                digits += ch
            else:
                break
        out.append(int(digits) if digits else 0)
    return tuple(out)


print("==> Checking marketplace version vs latest tag")
mk_version = mk.get("version")
if not mk_version:
    print("  skip: marketplace.json has no top-level 'version'")
elif not latest_tag:
    print("  skip: no 'v*' tags found")
else:
    mv, tv = semver(mk_version), semver(latest_tag)
    if mv == tv:
        ok(f"marketplace version {mk_version} matches latest tag {latest_tag}")
    elif mv > tv:
        ok(f"marketplace version {mk_version} ahead of latest tag {latest_tag} (release pending)")
    else:
        bad(f"marketplace version {mk_version} is behind latest tag {latest_tag}")

if errors:
    print(f"==> {errors} version problem(s) found")
    sys.exit(1)
print("==> All version checks passed")
PY
